# ── CampusTutor Backend — Environment Variables ──────────────────────────────
# Copy this file to .env and fill in your values.
# Never commit the actual .env file to version control.

# JWT secret — change this to a long random string in any shared environment
JWT_SECRET_KEY=campus-tutor-dev-secret-2026

# ── Mailtrap SMTP ─────────────────────────────────────────────────────────────
# 1. Sign up at https://mailtrap.io (free)
# 2. Go to Email Testing → Inboxes → Show Credentials
# 3. Paste your credentials below

MAIL_SERVER=smtp.mailtrap.io
MAIL_PORT=587
MAIL_USERNAME=your_mailtrap_username_here
MAIL_PASSWORD=your_mailtrap_password_here
MAIL_DEFAULT_SENDER=noreply@campustutor.local

# ── NOTE ──────────────────────────────────────────────────────────────────────
# If MAIL_USERNAME / MAIL_PASSWORD are left blank or this file doesn't exist,
# the OTP will be printed directly in the Flask terminal window instead.
# This is the fallback for development with no Mailtrap account.
